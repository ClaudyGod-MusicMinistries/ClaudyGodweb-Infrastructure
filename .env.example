################################################################################
#                    CLAUDYGOD INFRASTRUCTURE CONFIGURATION                   #
#                    (Shared Proxy Architecture - Production)                  #
#                                                                              #
# IMPORTANT: This file is a TEMPLATE. NEVER commit real secrets to git.       #
# Copy this to .env, fill in the actual values, and keep .env out of git.    #
#                                                                              #
# To generate secure random values:                                           #
#   $ openssl rand -base64 32    # for 256-bit keys                          #
#   $ openssl rand -base64 48    # for 384-bit keys                          #
#                                                                              #
# Network: Uses shared traefik-public (managed by ~/apps/proxy)              #
# Error handling: Via shared error-service (maintenance pages 500-599)        #
#                                                                              #
################################################################################

################################################################################
#                          DOMAIN CONFIGURATION                                #
################################################################################

# Primary domain (frontend) - with www redirect
DOMAIN=claudygod.org

# API subdomain
API_DOMAIN=api.claudygod.org

# Blog/content subdomain (optional)
BLOG_DOMAIN=blog.claudygod.org

# Let's Encrypt certificate alert email (shared proxy admin)
ACME_EMAIL=admin@claudygod.org

# Timezone (for logging and database)
TZ=UTC

################################################################################
#                       IMAGE REGISTRY (GitHub Container Registry)            #
################################################################################

# Image tag to deploy
# Use git SHA or semantic version in production: v1.0.0, abc123def, latest
# Examples: latest, v1.2.3, abc1234def567 (git SHA)
TAG=latest

# GitHub Container Registry organization
REGISTRY=ghcr.io/claudygod-musicministries

# Fully qualified image names (constructed from above)
# Format: ghcr.io/org/repo:tag
FRONTEND_IMAGE=${REGISTRY}/website2.0:${TAG}
BACKEND_IMAGE=${REGISTRY}/cgm-backend:${TAG}

# Optional: Docker Hub (if not using GHCR)
# REGISTRY=docker.io/claudygod
# FRONTEND_IMAGE=${REGISTRY}/website2.0:${TAG}
# BACKEND_IMAGE=${REGISTRY}/cgm-backend:${TAG}

################################################################################
#                          POSTGRESQL DATABASE                                 #
################################################################################

# Database name
POSTGRES_DB=claudygod

# Database superuser (non-root for security)
POSTGRES_USER=cgm

# Database password (CRITICAL: use openssl rand -base64 32)
# Minimum 32 characters for production
POSTGRES_PASSWORD=CHANGE_ME_MIN_32_CHARS

# Connection timeout (seconds)
POSTGRES_CONNECT_TIMEOUT=10

# Optional: use external PostgreSQL connection string instead of container
# Uncomment to use Supabase or another managed PostgreSQL service:
# POSTGRES_HOST=db.supabase.co
# POSTGRES_PORT=5432
# This will skip the local PostgreSQL container setup.

################################################################################
#                             REDIS CACHE & SESSIONS                           #
################################################################################

# Redis password (CRITICAL: use openssl rand -base64 32)
# Minimum 32 characters for production
REDIS_PASSWORD=CHANGE_ME_MIN_32_CHARS

# Redis max memory policy (LRU eviction when full)
REDIS_MAX_MEMORY_POLICY=allkeys-lru

################################################################################
#                        JWT & ENCRYPTION SECRETS                              #
################################################################################

# JWT signing key for authentication tokens
# Minimum 48 bytes (384 bits) for HS512
# Generate: openssl rand -base64 48
# CRITICAL: change this in production
JWT_KEY=CHANGE_ME_MIN_48_CHARS

# AES-256 encryption key for sensitive fields
# Must be exactly 32 bytes when base64-decoded (256 bits)
# Generate: openssl rand -base64 32 | tr -d '\n'
# CRITICAL: change this in production
ENCRYPTION_KEY=CHANGE_ME_32_BYTES

################################################################################
#                          EMAIL (SMTP) CONFIGURATION                          #
################################################################################

# Gmail SMTP configuration
# https://myaccount.google.com/apppasswords (create app-specific password)
# Do NOT use your main Gmail password — use an app-specific password
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USERNAME=noreply@claudygod.org
EMAIL_SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD

# Sender email details
EMAIL_FROM_NAME=ClaudyGod Music Ministries
EMAIL_FROM_ADDRESS=noreply@claudygod.org

# Admin email (for notifications, contact form responses, alerts)
EMAIL_ADMIN=admin@claudygod.org

# Optional: Enable email debugging
# EMAIL_LOG_LEVEL=Debug

# Optional: email logging (uncomment for debugging)
# EMAIL_LOG_LEVEL=Debug

################################################################################
#                        PAYSTACK PAYMENT GATEWAY                              #
################################################################################

# Paystack secret key (server-side, never expose to browser)
# Get from: https://dashboard.paystack.com/#/settings/developers
# Lives in NGN business account
PAYSTACK_SECRET_KEY=sk_live_CHANGE_ME

# Paystack public key (safe to expose to browser via NEXT_PUBLIC_)
# Paired with secret key above
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_CHANGE_ME

################################################################################
#                     ANTHROPIC CLAUDE AI (PAYMENT VALIDATION)                 #
################################################################################

# Claude API key for AI-powered payment slip validation
# Validates Zelle and Nigerian bank transfer screenshots
# Get from: https://console.anthropic.com/settings/keys
# https://www.anthropic.com/api/keys
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Claude model to use (recommended: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

################################################################################
#                         FRONTEND (NEXT.JS) VARIABLES                        #
################################################################################

# Backend API URL (exposed to browser, used for fetch calls)
# Must be the production domain in production
NEXT_PUBLIC_API_URL=https://api.claudygod.com

# Frontend site URL (for canonical tags, meta tags, redirects)
NEXT_PUBLIC_SITE_URL=https://claudygod.com

# Disable Next.js telemetry data collection
NEXT_TELEMETRY_DISABLED=1

# Optional: Next.js analytics
# NEXT_PUBLIC_ANALYTICS_KEY=

################################################################################
#                      DATABASE CONNECTION STRING (AUTO)                       #
################################################################################

# This is auto-constructed by Docker Compose from above variables.
# Do not edit this manually unless running outside Docker.
#
# Example (for reference):
# Host=db;Port=5432;Database=claudygod;Username=cgm;Password=<POSTGRES_PASSWORD>;Pooling=true;MinPoolSize=1;MaxPoolSize=20;

################################################################################
#                         OPTIONAL ADVANCED SETTINGS                           #
################################################################################

# S3/Object Storage (if migrating file uploads to cloud)
# Uncomment and fill to enable S3 uploads instead of local /app/uploads
# S3_BUCKET_NAME=claudygod-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Slack webhook for deployment notifications (GitHub Actions)
# Optional, but recommended for production
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Sentry error tracking (optional)
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# Feature flags (optional, for gradual rollouts)
# FEATURE_ENABLE_ZELLE_PAYMENTS=true
# FEATURE_ENABLE_NGN_BANK_TRANSFERS=true
# FEATURE_ENABLE_PRAYER_REQUESTS=true
