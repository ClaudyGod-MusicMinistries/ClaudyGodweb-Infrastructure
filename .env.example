################################################################################
#                    CLAUDYGOD INFRASTRUCTURE CONFIGURATION                   #
#                   (Supabase + Brevo + Shared Proxy)                         #
#                                                                              #
# IMPORTANT: This file is a TEMPLATE. NEVER commit real secrets to git.       #
# Copy this to .env, fill in the actual values, and keep .env out of git.    #
#                                                                              #
# Production Setup:                                                            #
# - Database: Supabase PostgreSQL (managed)                                   #
# - Email: Brevo SMTP Relay (managed)                                        #
# - Reverse Proxy: Traefik v3.6 (shared at ~/apps/proxy)                    #
# - Monitoring: Grafana (optional, self-hosted)                              #
#                                                                              #
################################################################################

################################################################################
#                          DOMAIN CONFIGURATION                                #
################################################################################

# Primary domain (frontend)
DOMAIN=claudygod.org

# API subdomain
API_DOMAIN=api.claudygod.org

# Grafana monitoring dashboard (optional, set to empty to disable)
GRAFANA_DOMAIN=metrics.claudygod.org

# Let's Encrypt certificate alert email
ACME_EMAIL=admin@claudygod.org

# Timezone for logging and database
TZ=UTC

################################################################################
#                       IMAGE REGISTRY (GitHub Container Registry)            #
################################################################################

# Image tag to deploy (use git SHA or semantic version in production)
TAG=latest

# GitHub Container Registry organization
REGISTRY=ghcr.io/claudygod-musicministries

# Fully qualified image names
FRONTEND_IMAGE=${REGISTRY}/website2.0:${TAG}
BACKEND_IMAGE=${REGISTRY}/cgm-backend:${TAG}

################################################################################
#                  SUPABASE PostgreSQL CONNECTION STRING                      #
################################################################################

# Supabase provides a managed PostgreSQL database with connection pooling
#
# Connection String Format (from Supabase dashboard):
# postgresql://[user]:[password]@[host]:[port]/[database]
#
# Example:
# postgresql://postgres.ktzhbaqumdvypegnsgok:YOUR-PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
#
# Key Points:
# - Use the "Shared Pooler" connection (IPv4, port 5432)
# - NOT the "Direct Connection" (unless you're on IPv6)
# - Keep this secret — it contains your database password
# - Supabase handles backups, replication, scaling automatically
#
# Get this from: https://app.supabase.com/project/[project-id]/settings/database

SUPABASE_CONNECTION_STRING=postgresql://postgres.ktzhbaqumdvypegnsgok:CHANGE_ME_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

################################################################################
#                             REDIS CACHE & SESSIONS                           #
################################################################################

# Redis password (local Redis, not Supabase)
# Generate: openssl rand -base64 32
REDIS_PASSWORD=E1eU3Jyegxto2eEFDTHwTw0JUtzffbkoPufVkkX2SKk=

# Redis max memory policy (LRU eviction when full)
REDIS_MAX_MEMORY_POLICY=allkeys-lru

################################################################################
#                        JWT & ENCRYPTION SECRETS                              #
################################################################################

# JWT signing key for authentication tokens
# Minimum 48 bytes (384 bits) for HS512
# Generate: openssl rand -base64 48
JWT_KEY=0+pxxFNwt9H2PRxY6kHzHjPQ55pFJ33+eeCAc9j+R5RRRbUS5FocO2QheKTA4WZP

# AES-256 encryption key for sensitive fields
# Exactly 32 bytes when base64-decoded (256 bits)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=fRMFn3gr0aenh683/K0d/I1WR2QjeKXiJmAAWEBuUTQ=

################################################################################
#                        BREVO EMAIL CONFIGURATION                             #
################################################################################

# Brevo SMTP Relay Service
# https://www.brevo.com/ (formerly Sendinblue)
#
# Brevo provides managed SMTP relay for transactional emails.
# No need to manage your own mail server.
#
# Configuration from Brevo Dashboard:
# Settings → SMTP & API → SMTP Details
#

# SMTP Relay Host (Brevo's SMTP relay server)
EMAIL_SMTP_HOST=smtp-relay.brevo.com

# SMTP Port (TLS encryption)
EMAIL_SMTP_PORT=587

# Brevo SMTP Login (provided by Brevo)
# Format: [SMTP_LOGIN]@smtp-brevo.com
# Find in: Brevo Dashboard → Settings → SMTP & API → SMTP Login
EMAIL_SMTP_USERNAME=a18467001@smtp-brevo.com

# Brevo SMTP Key (your Brevo API key for authentication)
# Find in: Brevo Dashboard → Settings → SMTP & API → SMTP Key
# This is NOT the REST API key — it's the SMTP-specific key
# Name: ClaudyGod-website
EMAIL_SMTP_PASSWORD=xsmtpsib-c46e3da1b1c5488d7da857363c79239938f9867544ecaf145d856dc68adf4d11-rd810YH8IZRiPJ7W


# Sender email details
EMAIL_FROM_NAME=ClaudyGod Music Ministries
EMAIL_FROM_ADDRESS=noreply@claudygod.org

# Admin email (for notifications, contact form responses)
EMAIL_ADMIN=admin@claudygod.org

################################################################################
#                        PAYSTACK PAYMENT GATEWAY                              #
################################################################################

# Paystack secret key (server-side, never expose to browser)
# Get from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_live_CHANGE_ME

# Paystack public key (safe to expose to browser via NEXT_PUBLIC_)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_CHANGE_ME

################################################################################
#                     ANTHROPIC CLAUDE AI (PAYMENT VALIDATION)                 #
################################################################################

# Claude API key for payment slip validation
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

################################################################################
#                         FRONTEND (NEXT.JS) VARIABLES                        #
################################################################################

# Backend API URL (exposed to browser)
NEXT_PUBLIC_API_URL=https://${API_DOMAIN}

# Frontend site URL (for meta tags, redirects)
NEXT_PUBLIC_SITE_URL=https://${DOMAIN}

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

################################################################################
#                          GRAFANA MONITORING                                  #
################################################################################

# Grafana admin password
# Generate a strong password: openssl rand -base64 32
# Keep this secret — it controls access to dashboards
GRAFANA_ADMIN_PASSWORD=qtf4/DFeV4yp964+9gDdDpeXFX20Ui4U5BxhJDpidvE=

# Grafana is optional — for infrastructure monitoring
# If GRAFANA_DOMAIN is empty, Grafana container won't be exposed
# But it will still run for internal metrics collection

################################################################################
#                            PRODUCTION CHECKLIST                              #
################################################################################

# Before deploying to production, verify:
#
# ✅ Supabase:
#    - Create project at https://supabase.com
#    - Get connection string from Project Settings → Database → Connection Pooler
#    - Use "Shared Pooler" (IPv4, port 5432)
#    - Test connection locally before deploying
#
# ✅ Brevo:
#    - Sign up at https://www.brevo.com/
#    - Verify sender email (noreply@claudygod.org)
#    - Get SMTP Login and SMTP Key from Dashboard → SMTP & API
#    - Test SMTP connection before deploying
#    - Whitelist IP address (your server) if needed
#
# ✅ Paystack:
#    - Create account at https://paystack.com/
#    - Get API keys from https://dashboard.paystack.com/#/settings/developers
#    - Use LIVE keys in production (not test keys)
#
# ✅ Anthropic Claude:
#    - Create account at https://console.anthropic.com/
#    - Generate API key from Console Settings
#    - Set up billing for usage
#
# ✅ DNS:
#    - Point claudygod.org → Server IP
#    - Point api.claudygod.org → Server IP
#    - Point metrics.claudygod.org → Server IP (if using Grafana)
#
# ✅ Server:
#    - Shared proxy running (~/apps/proxy/docker-compose up -d)
#    - traefik-public network exists (docker network ls | grep traefik-public)
#    - Ports 80/443 open in firewall
#    - SSH access configured for CI/CD
#
# ✅ GitHub:
#    - Build and push images to GHCR
#    - Set GitHub Actions secrets (if using auto-deploy)
#
# ✅ Deployment:
#    - Fill .env with all values
#    - Run: docker compose up -d
#    - Verify health endpoints
#    - Check Grafana dashboard (optional)
#    - Monitor logs: make logs
#
################################################################################
