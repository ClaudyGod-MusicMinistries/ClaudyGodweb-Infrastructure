################################################################################
#                    CLAUDYGOD INFRASTRUCTURE CONFIGURATION                   #
#                   (Supabase + Brevo + Shared Proxy)                         #
#                                                                              #
# IMPORTANT: This file is a TEMPLATE. NEVER commit real secrets to git.       #
# Copy this to .env, fill in actual values, keep .env out of git.             #
#                                                                              #
# Production Setup:                                                            #
#   Database:      Supabase PostgreSQL (managed)                              #
#   Email:         Brevo SMTP Relay (managed)                                 #
#   Reverse Proxy: Traefik v3 (shared at ~/apps/proxy)                       #
#   Monitoring:    Grafana (optional, self-hosted)                            #
#   Images:        GHCR (ghcr.io/claudygod-musicministries)                  #
################################################################################

################################################################################
#                          DOMAIN CONFIGURATION                                #
################################################################################

DOMAIN=claudygod.org
API_DOMAIN=api.claudygod.org
GRAFANA_DOMAIN=metrics.claudygod.org
ACME_EMAIL=admin@claudygod.org
TZ=UTC

################################################################################
#                       IMAGE REGISTRY (GHCR)                                 #
#                                                                              #
# Images are built and pushed automatically by GitHub Actions on every        #
# push to main in the CGM-Backend and website2.0 repositories.                #
#                                                                              #
# Tag options:                                                                 #
#   latest     — always the most recent build from main                       #
#   sha-abc123 — pinned to a specific commit (safe for rollbacks)             #
################################################################################

REGISTRY=ghcr.io/claudygod-musicministries
TAG=latest

BACKEND_IMAGE=ghcr.io/claudygod-musicministries/cgm-api:${TAG}
FRONTEND_IMAGE=ghcr.io/claudygod-musicministries/cgm-web:${TAG}

################################################################################
#                  SUPABASE PostgreSQL CONNECTION STRING                      #
#                                                                              #
# Get from: Supabase Dashboard → Project Settings → Database                  #
#   → Connection Pooler → "Shared Pooler" (IPv4, port 5432)                  #
# Format: postgresql://[user]:[password]@[pooler-host]:5432/postgres           #
################################################################################

SUPABASE_CONNECTION_STRING=postgresql://postgres.CHANGE_ME:CHANGE_ME_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

################################################################################
#                             REDIS CACHE                                      #
#                                                                              #
# Generate: openssl rand -base64 32                                            #
################################################################################

REDIS_PASSWORD=CHANGE_ME
REDIS_MAX_MEMORY_POLICY=allkeys-lru

################################################################################
#                        JWT & ENCRYPTION SECRETS                              #
#                                                                              #
# JWT_KEY:        openssl rand -base64 48   (minimum 48 bytes)                #
# ENCRYPTION_KEY: openssl rand -base64 32   (AES-256, 32 bytes)               #
################################################################################

JWT_KEY=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

################################################################################
#                        BREVO EMAIL (SMTP RELAY)                             #
#                                                                              #
# Get SMTP credentials from: Brevo Dashboard → Settings → SMTP & API          #
# Verify sender domain before going live.                                      #
################################################################################

EMAIL_SMTP_HOST=smtp-relay.brevo.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=CHANGE_ME@smtp-brevo.com
EMAIL_SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM_NAME=ClaudyGod Music Ministries
EMAIL_FROM_ADDRESS=noreply@claudygod.org
EMAIL_ADMIN=admin@claudygod.org

################################################################################
#                        PAYSTACK PAYMENT GATEWAY                              #
#                                                                              #
# Get from: https://dashboard.paystack.com/#/settings/developers              #
# Use LIVE keys in production (not test keys).                                 #
################################################################################

PAYSTACK_SECRET_KEY=sk_live_CHANGE_ME
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_CHANGE_ME

################################################################################
#                     ANTHROPIC CLAUDE AI                                      #
#                                                                              #
# Get from: https://console.anthropic.com/settings/keys                       #
################################################################################

ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
CLAUDE_MODEL=claude-sonnet-4-6

################################################################################
#                         FRONTEND (NEXT.JS) VARIABLES                        #
################################################################################

NEXT_PUBLIC_API_URL=https://api.claudygod.org
NEXT_PUBLIC_SITE_URL=https://claudygod.org
NEXT_TELEMETRY_DISABLED=1

################################################################################
#                          GRAFANA MONITORING                                  #
#                                                                              #
# Generate: openssl rand -base64 32                                            #
################################################################################

GRAFANA_ADMIN_PASSWORD=CHANGE_ME

################################################################################
#                            PRODUCTION CHECKLIST                              #
################################################################################

# Before first deploy, verify:
#
# ✅ Supabase:   Project created, connection string from Pooler (IPv4, port 5432)
# ✅ Brevo:      Sender verified, SMTP Login + Key from dashboard
# ✅ Paystack:   LIVE API keys (not test)
# ✅ Anthropic:  API key created with billing set up
# ✅ DNS:        claudygod.org, api.claudygod.org, metrics.claudygod.org → server IP
# ✅ Server:     Shared Traefik proxy running (~/apps/proxy)
# ✅ Network:    docker network create traefik-public
# ✅ GHCR:       echo PAT | docker login ghcr.io -u USERNAME --password-stdin
# ✅ GitHub:     Set Actions secrets (VPS_HOST, VPS_USER, VPS_SSH_KEY, VPS_DEPLOY_PATH)
